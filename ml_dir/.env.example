# ── Grille ────────────────────────────────────────────────────────────────────
CELL_SIZE=250                   # Taille des cellules en mètres (Lambert93)

# ── KMeans ────────────────────────────────────────────────────────────────────
N_CLUSTERS=0                    # 0 = sélection automatique par score silhouette
KMEANS_RANDOM_STATE=42
KMEANS_N_INIT=10

# ── SHAP ──────────────────────────────────────────────────────────────────────
SHAP_TOP_N=3                    # Nombre de facteurs de risque affichés par cellule

# ── Poids scoring — particulier (exposition du logement) ──────────────────────
# La somme n'a pas besoin d'être égale à 1 (normalisé automatiquement)
W_PART_FLOOD=0.25
W_PART_ICU=0.13
W_PART_NAPPE=0.12
W_PART_ARGILE=0.10
W_PART_ZONE_HUMIDE=0.08
W_PART_IN_PPRT=0.08
W_PART_DIST_SITES_POL=0.08
W_PART_DIST_INDUSTRIE=0.06
W_PART_WATER_INFILTRATION=0.05
W_PART_GREEN_COVER=0.05

# ── Poids scoring — élu (exposition de la population) ─────────────────────────
W_ELU_FLOOD=0.20
W_ELU_POPULATION=0.18
W_ELU_ICU=0.11
W_ELU_NAPPE=0.10
W_ELU_ZONE_HUMIDE=0.08
W_ELU_ARGILE=0.08
W_ELU_IN_PPRT=0.07
W_ELU_DIST_SITES_POL=0.07
W_ELU_DIST_INDUSTRIE=0.05
W_ELU_WATER_INFILTRATION=0.04
W_ELU_GREEN_COVER=0.02
